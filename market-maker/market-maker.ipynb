    "import numpy as np\n",
    "import torch\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from src.process import RFQ"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [],
   "source": [
    "def scurve(delta, alpha, beta, delta_0):\n",
    "    return 1 / (1 + torch.exp(alpha + beta / delta_0 * delta))\n",
    "\n",
    "\n",
    "def utility(\n",
    "    ask_delta,\n",
    "    bid_delta,\n",
    "    q,\n",
    "    z,\n",
    "    ask_lamda,\n",
    "    bid_lamda,\n",
    "    gamma,\n",
    "    alpha,\n",
    "    beta,\n",
    "    delta_0,\n",
    "    kappa,\n",
    "    delta_t,\n",
    "    sigma,\n",
    "):\n",
    "    t = ask_delta.shape[1]\n",
    "\n",
    "    res = 0\n",
    "    for i in range(t):\n",
    "        res += (\n",
    "            z\n",
    "            * ask_delta[:, i]\n",
    "            * ask_lamda[:, i]\n",
    "            * scurve(ask_delta[:, i], alpha, beta, delta_0)\n",
    "            + z\n",
    "            * bid_delta[:, i]\n",
    "            * bid_lamda[:, i]\n",
    "            * scurve(bid_delta[:, i], alpha, beta, delta_0)\n",
    "            + kappa * (ask_lamda[:, i] - bid_lamda[:, i]) * q[:, i]\n",
    "            - gamma / 2 * q[:, i] ** 2 * sigma**2\n",
    "        ) * delta_t\n",
    "    return torch.mean(res)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
